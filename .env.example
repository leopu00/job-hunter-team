# ============================================================
# .env.example — job-hunter-team
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# ── REQUIRED ────────────────────────────────────────────────

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── PATH JHT ────────────────────────────────────────────────
# I path sono fissi: ~/.jht (nascosto, agenti/db/config) e
# ~/Documents/Job Hunter Team (visibile, CV e output utente).
# Le env var qui sotto servono solo per test/CI per isolare
# i test dai dati reali dell'utente. Non serve impostarle in
# produzione.
# JHT_HOME=~/.jht
# JHT_USER_DIR=~/Documents/Job Hunter Team

# ── OPTIONAL — NOTIFICATIONS ────────────────────────────────

# Telegram bot token — get from @BotFather
# Leave empty to disable Telegram notifications
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID — send /start to your bot to get it
TELEGRAM_CHAT_ID=

# ── OPTIONAL — EMAIL MONITORING ─────────────────────────────

# Gmail address to monitor for application responses
JH_PERSONAL_EMAIL=

# Gmail app password (not your main password)
# Enable at: https://myaccount.google.com/apppasswords
JH_PERSONAL_PASSWORD=

# IMAP server (default: imap.gmail.com)
# JH_IMAP_SERVER=imap.gmail.com
# JH_IMAP_PORT=993

# ── OPTIONAL — LINKEDIN ──────────────────────────────────────

# Path to Chrome persistent profile for authenticated LinkedIn checks
# Leave empty to skip LinkedIn verification
# LINKEDIN_PROFILE_PATH=

# ── OPTIONAL — DATABASE ─────────────────────────────────────

# Leave empty to use SQLite (default, local-first)
# Set to a PostgreSQL URL for multi-user deployments
# DATABASE_URL=postgresql://user:password@localhost:5432/jobhunter

# ── OPTIONAL — GOOGLE SHEETS ────────────────────────────────

# Google Sheets ID for exporting the dashboard
# Leave empty to disable
GOOGLE_SHEETS_ID=

# ── OPTIONAL — GOOGLE DRIVE ─────────────────────────────────

# Google Drive folder ID for uploading CV/CL PDFs
# Create a folder in your Drive, copy the ID from the URL
# Leave empty to disable Drive upload
JH_DRIVE_FOLDER_ID=

# Path to Google service account JSON (for Sheets integration)
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
# Save in shared/secrets/google-service-account.json
# GOOGLE_SERVICE_ACCOUNT_PATH=./shared/secrets/google-service-account.json

# ── OPTIONAL — SUPABASE (per sync SQLite → Supabase) ─────────

# Supabase URL e service role key (necessari per db_to_supabase.py e db_to_sheets.py)
# Trovabili in Supabase Dashboard → Settings → API
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# UUID dell'utente Supabase a cui associare i dati sincronizzati
# Se omesso, usa il primo utente trovato in candidate_profiles
# JHT_SUPABASE_USER_ID=

# ── OPTIONAL — SENTINELLA ─────────────────────────────────────

# Rate limit giornaliero (messaggi Claude, default: 1800)
# JHT_DAILY_LIMIT=1800
# Rate limit orario (default: 150)
# JHT_HOURLY_LIMIT=150
# Intervallo check in secondi (default: 60)
# JHT_CHECK_INTERVAL=60

# ── OPTIONAL — LLM PROVIDER ─────────────────────────────────

# Provider LLM di default (claude, openai, minimax). Default: claude
# JHT_LLM_PROVIDER=claude

# OpenAI API key — necessaria solo se usi provider openai
# OPENAI_API_KEY=

# Minimax API key — necessaria solo se usi provider minimax
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
