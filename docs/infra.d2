direction: right

row1: "" {
  style: {
    stroke: transparent
    fill: transparent
  }
  direction: down

  docker: "🐳 Docker Container" {
    team: "🎯 Agent Team" {
      capitano: "👨‍✈️ Capitano (Alfa)"
      scout: "🕵️‍♂️ Scout"
      analyst: "👨‍🔬 Analyst"
      scorer: "👨‍💻 Scorer"
      writer: "👨‍🏫 Writer"
      critic: "👨‍⚖️ Critic"
      sentinella: "💂 Sentinella"

      capitano -- scout
      capitano -- analyst
      capitano -- scorer
      capitano -- writer
      capitano -- critic
      capitano -- sentinella
    }

    storage: "💾 Storage" {
      sqlite: "📊 SQLite\nprofilo, posizioni,\ncandidature, score"
      file: "📁 File\nCV, cover letter,\nreport PDF"
    }

    team <-> storage
  }

  cloud_col: "☁️ Cloud" {
    style: {
      stroke: "#999"
      stroke-dash: 5
      fill: transparent
      font-size: 20
    }
    cloud: "☁️💾 Cloud Storage" {
      supabase: "☁️📊 Supabase"
      gdrive: "☁️📁 Google Drive"
    }
    site: "🌐☁️ jobhunterteam.ai"
    vps: "☁️🖥️ VPS" {
      docker: "🐳 Docker" {
        style.stroke-dash: 4
        team: "🎯 Agent Team"
        storage: "💾 Storage"
      }
    }
    cloud <-> site: {
      style.stroke-dash: 4
    }
  }

}

row2: "" {
  style: {
    stroke: transparent
    fill: transparent
  }
  direction: down

  pc: "🖥️ PC locale" {
    docker: "🐳 Docker" {
      style.stroke-dash: 4
      team: "🎯 Agent Team"
      storage: "💾 Storage"
    }
    dashboard_locale: "🌐 localhost:3000"
  }
  telegram: "💬 Telegram"
  browser: "🧭 Browser"
}

utente: "👤 Utente"
junction: "Cloud\nO\nLocale?" {
  shape: diamond
  style: {
    fill: "#fef3c7"
    stroke: "#f59e0b"
    stroke-width: 2
  }
}

row1.cloud_col.vps.docker.storage <-> row1.cloud_col.cloud: sync {
  style.stroke-dash: 4
}
row2.pc.docker.storage <-> row2.pc.dashboard_locale
row2.browser <-> row1.cloud_col.site
row1.docker -> junction: {
  target-arrowhead.shape: none
}
junction -> row2.pc.docker: locale
junction -> row1.cloud_col.vps.docker: cloud
row2.pc.docker.team <-> row2.pc.docker.storage
row1.cloud_col.vps.docker.team <-> row1.cloud_col.vps.docker.storage
utente <-> row2.browser
row2.browser <-> row2.pc.dashboard_locale
utente <-> row2.telegram
row2.telegram <-> row2.pc.docker.team
row2.telegram <-> row1.cloud_col.vps.docker.team
