# ══════════════════════════════════════════════════════════════
# .gitignore — Job Hunter Team
# REGOLA: se non sei sicuro, NON committare. Chiedi prima.
# ══════════════════════════════════════════════════════════════

# ── SECRETS E CONFIG LOCALI ──────────────────────────────────
.env
.env.local
.env.*.local
.mcp.json
*.mcp.json
CLAUDE.md
.agents/
auth-state.json
google-oauth-*.json
google-service-account.json
linkedin-cookies.json
.secrets-patterns

# ── DATI PERSONALI — MAI committare ─────────────────────────
# PDF: CV, cover letter, documenti personali
*.pdf

# Database SQLite (dati candidature)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Applications: CV e lettere generate
shared/data/applications/

# LinkedIn: alerts, job data
shared/data/linkedin-alerts/
shared/data/incoming/

# Telegram: sessioni e dati personali (il bridge code e' versionato)
shared/telegram/sessions/
shared/telegram/*.session

# Screenshot con dati personali
*.png
!web/public/**/*.png
!web/app/**/*.png
!assets/banner.png
!desktop/assets/icon.png

# Gap report e dati analisi personali
shared/data/gap-report.json

# Candidate profile (dati personali)
candidate_profile.yml
candidate_profile.example.yml

# ── CHIAVI E CERTIFICATI ─────────────────────────────────────
shared/secrets/*
!shared/secrets/.gitkeep
*.pem
*.key
*.p12
*.pfx

# ── BUILD E DIPENDENZE ──────────────────────────────────────
node_modules/

# Rust build artifacts
launcher/target/

# Desktop build artifacts
desktop/dist/
desktop/app-payload/

# Download binaries (served at runtime, not committed)
web/public/downloads/

# Generato dal buildCommand di vercel.json: copia di scripts/install.sh
# servito su jobhunterteam.ai/install.sh. Non committarlo: la fonte di
# verita' resta scripts/install.sh, il copy avviene a build time.
web/public/install.sh
.next/
__pycache__/
*.pyc
*.pyo
.vercel/
dist/
build/
!desktop/build/

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/

# ── CLAUDE CODE ──────────────────────────────────────────────
.claude/

# ── PLAYWRIGHT MCP ───────────────────────────────────────────
.playwright-mcp/
.vercel

# ── SUPABASE ─────────────────────────────────────────────────────────────────
supabase/.temp/

# ── DEV SERVER LOGS ──────────────────────────────────────────────────────────
.next-dev-*.log
.next-dev-*.err.log

# ── E2E MANUAL TEST RUNS ─────────────────────────────────────────────────────
# Sessioni manuali di test end-to-end (note, screenshot, output di checkup, ecc.)
# Gli e2e automatizzati stanno in e2e/ e sono versionati normalmente.
e2e-runs/

# ── DEV LAUNCHER LOGS ────────────────────────────────────────────────────────
# Log generati da scripts/dev-up.sh (host Next su :3001)
.dev-logs/

# ── THROTTLE SANDBOX ─────────────────────────────────────────────────────────
# Micro-ambiente per testare jht-throttle con kimi reale (repo separata dentro)
seriea-sandbox/
