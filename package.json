{
  "name": "job-hunter-team",
  "version": "0.1.4",
  "description": "> Un framework multi-agente AI open-source che automatizza la tua ricerca lavoro — dalla scoperta di posizioni alla scrittura di CV e cover letter su misura.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "npm run lint --prefix web",
    "format:check": "npx prettier --check \"web/app/**/*.{ts,tsx}\" \"shared/**/*.ts\"",
    "desktop:dev": "npm --prefix desktop run dev",
    "desktop:test": "npm --prefix desktop run test",
    "desktop:dist": "npm --prefix desktop run dist",
    "desktop:dist:mac": "npm --prefix desktop run dist:mac",
    "desktop:dist:win": "npm --prefix desktop run dist:win",
    "desktop:dist:linux": "npm --prefix desktop run dist:linux"
  },
  "keywords": [],
  "author": "Leone Emanuele Puglisi",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "next": "^16.2.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  }
}
