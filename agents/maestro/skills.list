# Skills the Maestro consumes from agents/_skills/.
# One name per line. Lines starting with `#` and blank lines are ignored.
# The launcher (start-agent.sh) reads this file at boot and copies the
# listed skills into the agent's ~/.claude/skills/ runtime workspace.
# Note: db-query is read-only — the Maestro never writes to the DB.
tmux-send
db-query
