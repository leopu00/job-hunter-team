# Job Hunter Team — Web App — variabili d'ambiente
#
# Copia questo file in .env.local e compila i valori:
#   cp web/.env.example web/.env.local
#
# Ottieni le credenziali dal tuo progetto Supabase:
#   https://app.supabase.com → Settings → API

# ── Supabase (obbligatorio) ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Solo server-side. Non usare nel browser.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Google Sheets (opzionale) ───────────────────────────────────────────────
# ID del foglio Google per l'esportazione candidature
# Trova l'ID nell'URL: docs.google.com/spreadsheets/d/<ID>/edit
NEXT_PUBLIC_GOOGLE_SHEETS_ID=
